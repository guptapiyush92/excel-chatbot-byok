<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*"
           modules="httpPlatformHandler" resourceType="Unspecified"/>
    </handlers>
    <httpPlatform processPath="C:\path\to\excel-chatbot\venv\Scripts\python.exe"
                  arguments="-m uvicorn api.main:app --host 0.0.0.0 --port %HTTP_PLATFORM_PORT%"
                  stdoutLogEnabled="true"
                  stdoutLogFile="C:\path\to\logs\stdout.log"
                  startupTimeLimit="60"
                  startupRetryCount="3"
                  processesPerApplication="4">
      <environmentVariables>
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
        <environmentVariable name="API_HOST" value="0.0.0.0" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
